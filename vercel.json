{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/next"
        }
    ],
    "env": {
        "MONGODB_URI": "@mongodb_uri",
        "JWT_SECRET": "@jwt_secret",
        "EMAIL_USER": "@email_user",
        "EMAIL_PASS": "@email_pass",
        "NEXT_PUBLIC_API_URL": "@next_public_api_url"
    }
}